# =============================================================================
# Single-Stock Attribution Engine — .gitignore
# =============================================================================

# --- Secrets / environment ---------------------------------------------------
.env
.env.*
!env.example
*.pem
*.key
secrets/

# --- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.eggs/
*.egg-info/
*.egg
build/
dist/
pip-wheel-metadata/

# Test / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.hypothesis/

# Jupyter
.ipynb_checkpoints/

# --- Node / Next.js (dashboard/) --------------------------------------------
node_modules/
.next/
out/
.turbo/
.vercel/
*.tsbuildinfo
next-env.d.ts

# --- Data / caches -----------------------------------------------------------
.cache/
data/raw/
data/processed/
*.duckdb
*.duckdb.wal
*.sqlite
*.sqlite3
*.db
*.dump

# Pickled model artifacts (use S3 / artifact bucket instead)
*.pkl
*.joblib

# Prefect / Celery
.prefect/
celerybeat-schedule
celerybeat.pid

# Local MinIO data
.minio/

# --- Logs --------------------------------------------------------------------
*.log
logs/

# --- IDEs / editors ----------------------------------------------------------
.vscode/
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~

# --- OS ----------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# --- Claude Code -------------------------------------------------------------
# Personal/local settings stay out of the repo; .claude/agents/ is committed.
.claude/settings.local.json
.claude/.session/

# --- Playwright --------------------------------------------------------------
test-results/
playwright-report/
playwright/.cache/

# --- Misc --------------------------------------------------------------------
*.bak
*.tmp
