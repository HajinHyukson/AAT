# =============================================================================
# Single-Stock Attribution Engine — environment template
# Copy this file to `.env` and fill in real values. Never commit `.env`.
#
# Sections:
#   1. App + environment
#   2. Anthropic API (LLM)
#   3. Postgres + TimescaleDB
#   4. Object storage (S3 / MinIO)
#   5. Redis / Celery
#   6. Free-tier adapters (MVP)         — required to run MVP
#   7. Licensed adapters (v2+)          — leave blank in MVP; gated by license_tier
#   8. Frontend / auth (Clerk)
#   9. Observability (optional but recommended)
#
# Adapter rule (see .claude/agents/data-adapter-engineer.md):
#   When ENV=production, the engine refuses to start if any adapter with
#   `license_tier: licensed` is enabled without its credentials present.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. App + environment
# -----------------------------------------------------------------------------
ENV=development                          # development | staging | production
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR
TZ=America/New_York                      # all attribution timestamps stored in UTC; this controls display
APP_SECRET_KEY=replace-with-a-long-random-string


# -----------------------------------------------------------------------------
# 2. Anthropic API
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL_ROUTINE=claude-sonnet-4-6     # filing classification, sentiment
ANTHROPIC_MODEL_REASONING=claude-opus-4-7     # transcripts, narrative layer
ANTHROPIC_MAX_RETRIES=3
ANTHROPIC_TIMEOUT_SECONDS=60


# -----------------------------------------------------------------------------
# 3. Postgres + TimescaleDB
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=attribution
POSTGRES_USER=attribution
POSTGRES_PASSWORD=replace-me
# Used by SQLAlchemy / Alembic / engine code. Must match the values above.
DATABASE_URL=postgresql+psycopg://attribution:replace-me@localhost:5432/attribution

# Read replica for dashboard / DuckDB ad-hoc queries (optional in MVP)
DATABASE_READ_URL=

# FaustCalc source snapshot import. These point at the separate FaustCalc feature
# store and local data directory; AAT remains the destination database.
FAUSTCALC_DATABASE_URL=postgresql+psycopg://faustcalc:replace-me@localhost:5432/faustcalc
FAUSTCALC_DATA_ROOT=C:\Users\gkwls\FaustCalc\data
# Source names used by FaustCalc migration jobs:
#   faustcalc_fmp_snapshot
#   faustcalc_sec_edgar_snapshot
#   faustcalc_feature_store


# -----------------------------------------------------------------------------
# 4. Object storage (raw filings, transcripts, news payloads)
# -----------------------------------------------------------------------------
# In dev, point this at a local MinIO. In prod, an S3 bucket.
S3_ENDPOINT_URL=http://localhost:9000     # leave blank for AWS S3
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio12345
S3_BUCKET_RAW=attribution-raw             # filings, transcripts, news html
S3_BUCKET_ARTIFACTS=attribution-artifacts # model artifacts, calibration reports


# -----------------------------------------------------------------------------
# 5. Redis (Celery broker + result backend)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2


# -----------------------------------------------------------------------------
# 6. Primary market-data adapter (MVP) — Financial Modeling Prep
#    license_tier: licensed (paid plan, but key-gated like free_api adapters)
#    Covers: prices, corporate actions, earnings, estimates, news, fundamentals,
#    Form 4, 13F. Does NOT cover macro (use FRED), style factors (use French),
#    short interest (use FINRA), or raw SEC filings (use EDGAR for auditability).
# -----------------------------------------------------------------------------
FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com/api
FMP_PLAN=starter                          # starter | premium | ultimate | enterprise
FMP_RATE_LIMIT_PER_MIN=300                # adjust to your plan's cap
FMP_TIMEOUT_SECONDS=30


# -----------------------------------------------------------------------------
# 7. Free-tier supplementary adapters (MVP)
#    license_tier: public | free_api
# -----------------------------------------------------------------------------

# SEC EDGAR — free, official. Requires a contact User-Agent per SEC fair-use.
EDGAR_USER_AGENT="Single-Stock Attribution Research contact@example.com"
EDGAR_RATE_LIMIT_PER_SEC=10

# FRED (Federal Reserve Economic Data) — free with API key.
FRED_API_KEY=

# Kenneth French data library — no key, but cache directory needed.
FRENCH_DATA_CACHE_DIR=./.cache/french

# FINRA short interest — public file feed; no auth, but URL is rate-limited.
FINRA_USER_AGENT="Single-Stock Attribution Research contact@example.com"


# -----------------------------------------------------------------------------
# 7. Licensed adapters (v2+ — leave blank in MVP)
#    Each adapter has a *_ENABLED flag. The engine fail-closes in production
#    if `_ENABLED=true` without credentials. Per spec §14.3, MVP excludes all
#    unlicensed news/research feeds.
# -----------------------------------------------------------------------------

# Bloomberg (BLPAPI / Enterprise) — prices, estimates, news
BLOOMBERG_ENABLED=false
BLOOMBERG_API_KEY=
BLOOMBERG_HOST=
BLOOMBERG_PORT=

# FactSet — estimates, peer baskets
FACTSET_ENABLED=false
FACTSET_USERNAME=
FACTSET_API_KEY=

# LSEG / Refinitiv — prices, news
LSEG_ENABLED=false
LSEG_APP_KEY=
LSEG_USERNAME=
LSEG_PASSWORD=

# RavenPack — event feeds
RAVENPACK_ENABLED=false
RAVENPACK_API_KEY=

# Dataminr — alternative news feed
DATAMINR_ENABLED=false
DATAMINR_CLIENT_ID=
DATAMINR_CLIENT_SECRET=

# OCC / OPRA — options open interest, IV (v2+ for the positioning/options layer)
OCC_ENABLED=false
OCC_API_KEY=


# -----------------------------------------------------------------------------
# 8. Frontend / Auth (dashboard)
# -----------------------------------------------------------------------------
# Clerk publishable + secret key for the Next.js dashboard.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx
# Backend API base URL the dashboard talks to.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000


# -----------------------------------------------------------------------------
# 9. Observability (optional; recommended before pilot)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
PREFECT_API_URL=                          # e.g. https://api.prefect.cloud/api/accounts/.../workspaces/...
PREFECT_API_KEY=
